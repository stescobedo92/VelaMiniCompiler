# Run with: vela run examples/factorial.vela

include vela.core;

fn factorial(value: Int) -> Int {
    assert value >= 0, "factorial requires a non-negative Int";
    if value == 0 {
        return 1;
    } else {
        return value * factorial(value - 1);
    }
}

fn main() -> Int {
    let input: Int = 10;
    let result = factorial(input);
    print(result);
    return 0;
}
