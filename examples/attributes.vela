@since("0.2.0")
@experimental
class Command(name: Text) {
    @deprecated("Use run instead.")
    fn execute() -> Void {
        print(name);
    }

    @since("0.2.0")
    fn run() -> Void {
        print("running " + name);
    }
}

@doc(hidden)
fn internal_version() -> Text {
    return "0.2.0";
}

fn main() -> Void {
    let command = Command("build");
    command.run();
    print(internal_version());
}
